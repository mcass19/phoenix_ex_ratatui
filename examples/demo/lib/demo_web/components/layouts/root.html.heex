<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()} />
    <title>{assigns[:page_title] || "phoenix_ex_ratatui demo"}</title>
    <script defer phx-track-static type="text/javascript" src="/assets/app.js"></script>
    <style>
      body { margin: 0; background: #1a1a1a; color: #eaeaea; }
      a { color: #729fcf; }
      kbd { background: #333; padding: 0 0.3em; border-radius: 3px; }
      code { background: #333; padding: 0 0.3em; border-radius: 3px; }
    </style>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
